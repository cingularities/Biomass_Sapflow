    sd_increment    = sqrt(SD_biomass^2 + lag(SD_biomass)^2),
    se_increment    = sd_increment / sqrt(N_trees),
    ci95_inc_lower  = increment_kg_yr - 1.96 * se_increment,
    ci95_inc_upper  = increment_kg_yr + 1.96 * se_increment
  ) %>%
  ungroup() %>%
